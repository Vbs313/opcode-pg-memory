# ============================================================
# opcode-pg-memory 凭证配置
#
# 存放位置: ~/.opencode-pg-memory/.env
# (可由 PG_MEMORY_DATA_DIR 环境变量覆盖)
#
# 此文件仅存凭证 (API keys, DB passwords)。
# 非敏感配置请放在 ~/.config/opencode/pg-memory.jsonc
# 或 ~/.opencode-pg-memory/settings.json
#
# 迁移: 如果插件根目录有旧的 .env，请复制到新位置:
#   mkdir ~\.opencode-pg-memory
#   copy .env ~\.opencode-pg-memory\.env
# ============================================================

# === PostgreSQL 连接 ===
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=PGOMO
PG_USER=opencode
PG_PASSWORD=your_password_here

# === Embedding API Keys (按需配置) ===
# OpenAI (如使用 text-embedding-3-small)
# OPENAI_API_KEY=sk-...

# DeepSeek (如使用 text-embedding-v2)
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
