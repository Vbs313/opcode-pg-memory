{
  "name": "opcode-pg-memory",
  "version": "2.2.0",
  "description": "OpenCode plugin for persistent memory using PostgreSQL + pgvector — four-layer memory architecture with topic segmentation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opcode-pg-memory": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node && bun build ./src/cli.ts --outfile ./dist/cli.js --target node && bun build ./mcp-server.ts --outfile ./dist/mcp-server.js --target node && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "opencode",
    "plugin",
    "memory",
    "postgresql",
    "pgvector",
    "hindsight",
    "mcp",
    "agent"
  ],
  "author": "Vbs313",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vbs313/opcode-pg-memory"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "chat.message",
      "event",
      "tool.execute.before",
      "tool.execute.after",
      "experimental.session.compacting"
    ]
  },
  "files": [
    "dist",
    "scripts/migration-v2.sql",
    ".env.example",
    "README.md"
  ],
  "dependencies": {
    "pg": "^8.11.3",
    "pgvector": "^0.1.8",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "uuid": "^9.0.1",
    "crypto-js": "^4.2.0",
    "openai": "^4.20.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/crypto-js": "^4.2.1",
    "typescript": "^5.3.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
