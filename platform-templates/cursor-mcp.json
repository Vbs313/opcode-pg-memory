{
  "mcpServers": {
    "opcode-pg-memory": {
      "type": "stdio",
      "command": "node",
      "args": [
        "PATH_TO_OPCODE_PG_MEMORY/dist/mcp-server.js"
      ],
      "env": {
        "PG_HOST": "localhost",
        "PG_PORT": "5432",
        "PG_DATABASE": "opencode_memory",
        "PG_USER": "opencode",
        "PG_PASSWORD": "your_password_here",
        "PG_MEMORY_PLATFORM": "cursor"
      }
    }
  }
}
